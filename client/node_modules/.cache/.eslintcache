ect = cb => {\n    console.log(\"Connecting\");\n\n    socket.onopen = () => {\n        console.log(\"Successfully Connected\");\n    }\n\n    socket.onmessage = msg => {\n        console.log(msg)\n        cb(msg)\n    }\n\n    socket.onclose = e => {\n        console.log(\"Socket Closed Connection: \", e)\n    }\n\n    socket.onerror = err => {\n        console.log(\"Socket error \", err)\n    }\n}\n\nlet sendMsg = msg => {\n    console.log(\"sending msg: \", msg);\n    socket.send(msg);\n}\n\n\nexport {connect, sendMsg}\n",{"ruleId":"29","severity":1,"message":"30","line":1,"column":1,"nodeType":"31","messageId":"32","fix":"33"},"unicode-bom","Unexpected Unicode BOM (Byte Order Mark).","Program","unexpected",{"range":"34","text":"35"},[-1,0],""]